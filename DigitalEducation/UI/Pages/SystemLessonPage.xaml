<UserControl x:Class="DigitalEducation.SystemLessonsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,20">
        <StackPanel UseLayoutRounding="True">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,32" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="80" Height="80" Background="{DynamicResource SuccessBrush}" CornerRadius="16" Margin="0,0,20,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <Image Source="/Assets/Icons/White/Monitor.png" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Операционная система" FontSize="20" Foreground="{DynamicResource SuccessBrush}" FontWeight="Medium" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Освойте основные функции Windows: рабочий стол, окна, настройки, персонализацию и безопасность." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Прогресс курса" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="CourseProgressText" Grid.Column="1" Text="0/7 уроков" Foreground="{DynamicResource SuccessBrush}" TextOptions.TextFormattingMode="Display"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="Доступные уроки" Style="{DynamicResource SubtitleTextStyle}" TextOptions.TextFormattingMode="Display"/>
            <TextBlock Text="Выберите интересующий вас урок" Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,24"/>

            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,24" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Lesson1Number" Grid.Column="0" Width="80" Height="80" CornerRadius="16" Background="{DynamicResource SuccessBrush}" Margin="0,0,24,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <TextBlock Text="1" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Рабочий стол и панель задач" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Научитесь ориентироваться на рабочем столе, использовать панель задач, меню «Пуск» и системный трей." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус урока" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="Lesson1Status" Grid.Column="1" Text="Не пройден" Style="{DynamicResource BodyTextStyle}"/>
                        </Grid>
                        <WrapPanel UseLayoutRounding="True">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="10-15 минут" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="8 практических шагов" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{DynamicResource NavigationButtonStyle}" Height="80" VerticalAlignment="Center" Padding="24,0" Margin="24,0,0,0" Tag="OsLesson1" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal" UseLayoutRounding="True">
                            <Image x:Name="Lesson1Icon" Tag="Right" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Lesson1ButtonText" Text="Начать" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextOptions.TextFormattingMode="Display"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,24" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Lesson2Number" Grid.Column="0" Width="80" Height="80" CornerRadius="16" Background="{DynamicResource SuccessBrush}" Margin="0,0,24,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <TextBlock Text="2" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Управление окнами" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Сворачивание, разворачивание, закрытие окон и переключение между ними." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус урока" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="Lesson2Status" Grid.Column="1" Text="Не пройден" Style="{DynamicResource BodyTextStyle}"/>
                        </Grid>
                        <WrapPanel UseLayoutRounding="True">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="10 минут" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="6 практических шагов" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{DynamicResource NavigationButtonStyle}" Height="80" VerticalAlignment="Center" Padding="24,0" Margin="24,0,0,0" Tag="OsLesson2" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal" UseLayoutRounding="True">
                            <Image x:Name="Lesson2Icon" Tag="Right" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Lesson2ButtonText" Text="Начать" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextOptions.TextFormattingMode="Display"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,24" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Lesson3Number" Grid.Column="0" Width="80" Height="80" CornerRadius="16" Background="{DynamicResource SuccessBrush}" Margin="0,0,24,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <TextBlock Text="3" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Меню «Пуск» и поиск" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Запуск программ через поиск, закрепление в меню «Пуск» и на панели задач." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус урока" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="Lesson3Status" Grid.Column="1" Text="Не пройден" Style="{DynamicResource BodyTextStyle}"/>
                        </Grid>
                        <WrapPanel UseLayoutRounding="True">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="10 минут" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="7 практических шагов" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{DynamicResource NavigationButtonStyle}" Height="80" VerticalAlignment="Center" Padding="24,0" Margin="24,0,0,0" Tag="OsLesson3" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal" UseLayoutRounding="True">
                            <Image x:Name="Lesson3Icon" Tag="Right" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Lesson3ButtonText" Text="Начать" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextOptions.TextFormattingMode="Display"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,24" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Lesson4Number" Grid.Column="0" Width="80" Height="80" CornerRadius="16" Background="{DynamicResource SuccessBrush}" Margin="0,0,24,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <TextBlock Text="4" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Персонализация: фон и темы" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Измените фон рабочего стола, цветовую схему и примените тему оформления." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус урока" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="Lesson4Status" Grid.Column="1" Text="Не пройден" Style="{DynamicResource BodyTextStyle}"/>
                        </Grid>
                        <WrapPanel UseLayoutRounding="True">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="5-10 минут" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="5 практических шагов" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{DynamicResource NavigationButtonStyle}" Height="80" VerticalAlignment="Center" Padding="24,0" Margin="24,0,0,0" Tag="OsLesson4" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal" UseLayoutRounding="True">
                            <Image x:Name="Lesson4Icon" Tag="Right" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Lesson4ButtonText" Text="Начать" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextOptions.TextFormattingMode="Display"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,24" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Lesson5Number" Grid.Column="0" Width="80" Height="80" CornerRadius="16" Background="{DynamicResource SuccessBrush}" Margin="0,0,24,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <TextBlock Text="5" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Настройка даты, времени и языка" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Измените часовой пояс, формат времени и добавьте второй язык ввода." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус урока" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="Lesson5Status" Grid.Column="1" Text="Не пройден" Style="{DynamicResource BodyTextStyle}"/>
                        </Grid>
                        <WrapPanel UseLayoutRounding="True">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="5-10 минут" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="6 практических шагов" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{DynamicResource NavigationButtonStyle}" Height="80" VerticalAlignment="Center" Padding="24,0" Margin="24,0,0,0" Tag="OsLesson5" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal" UseLayoutRounding="True">
                            <Image x:Name="Lesson5Icon" Tag="Right" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Lesson5ButtonText" Text="Начать" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextOptions.TextFormattingMode="Display"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,24" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Lesson6Number" Grid.Column="0" Width="80" Height="80" CornerRadius="16" Background="{DynamicResource SuccessBrush}" Margin="0,0,24,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <TextBlock Text="6" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Программы и компоненты" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Просмотр установленных приложений, их сортировка и удаление." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус урока" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="Lesson6Status" Grid.Column="1" Text="Не пройден" Style="{DynamicResource BodyTextStyle}"/>
                        </Grid>
                        <WrapPanel UseLayoutRounding="True">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="5 минут" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="4 практических шага" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{DynamicResource NavigationButtonStyle}" Height="80" VerticalAlignment="Center" Padding="24,0" Margin="24,0,0,0" Tag="OsLesson6" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal" UseLayoutRounding="True">
                            <Image x:Name="Lesson6Icon" Tag="Right" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Lesson6ButtonText" Text="Начать" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextOptions.TextFormattingMode="Display"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{DynamicResource CardStyle}" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Lesson7Number" Grid.Column="0" Width="80" Height="80" CornerRadius="16" Background="{DynamicResource SuccessBrush}" Margin="0,0,24,0" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <TextBlock Text="7" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                    </Border>
                    <StackPanel Grid.Column="1" UseLayoutRounding="True">
                        <TextBlock Text="Безопасность и обновления" FontSize="16" FontWeight="Medium" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"/>
                        <TextBlock Text="Проверка обновлений Windows и использование Защитника Windows для безопасности." Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус урока" Style="{DynamicResource BodyTextStyle}"/>
                            <TextBlock x:Name="Lesson7Status" Grid.Column="1" Text="Не пройден" Style="{DynamicResource BodyTextStyle}"/>
                        </Grid>
                        <WrapPanel UseLayoutRounding="True">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="5-10 минут" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,8" BorderBrush="{DynamicResource PrimarySoftBrush}" BorderThickness="1" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <TextBlock Text="5 практических шагов" Foreground="{DynamicResource PrimaryDarkBrush}" FontWeight="Medium" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{DynamicResource NavigationButtonStyle}" Height="80" VerticalAlignment="Center" Padding="24,0" Margin="24,0,0,0" Tag="OsLesson7" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal" UseLayoutRounding="True">
                            <Image x:Name="Lesson7Icon" Tag="Right" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Lesson7ButtonText" Text="Начать" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextOptions.TextFormattingMode="Display"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>